# Copy this file to `.env.local` and fill real values before running the backend.
# Keep this file out of version control if it will contain secrets in your repo.

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
# Local example:
# postgresql://postgres:postgres@localhost:5432/DG-crm?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/DG-crm?schema=public

# Frontend (CORS)
FRONTEND_URL=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# JWT - set long, random secrets for production
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=30d
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRE=7d

# Admin bootstrap (used by prisma seed script)
ADMIN_EMAIL=elisee@dg-property.co.za
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator
MANAGER_EMAIL=manager@dg-property.co.za
MANAGER_PASSWORD=change_this_manager_password
MANAGER_NAME=Manager

# SMTP (Office 365 / STARTTLS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=eliseeweb@gmail.com
SMTP_PASS=jumi dioj fdlh xqkg
SMTP_FROM=eliseeweb@gmail.com

# Optional AWS / S3 settings
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Notes:
# 1) Set NEXT_PUBLIC_SOCKET_URL in the repo-root `.env.local` so frontend and backend agree on the realtime endpoint.
# 2) After copying to .env.local, run `npm run prisma:generate` then `npm run seed` to create the admin/manager users.
# 3) Keep secrets (JWT, DB credentials) private and rotate them in production.
