# SMTP only example (copy values into backend/.env.local or backend/.env.production)
#
# Option A — Gmail on port 465 (implicit TLS, recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false
SMTP_USER=eliseeweb@gmail.com
# Use a Gmail App Password (https://myaccount.google.com/apppasswords) — not your normal password
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=eliseeweb@gmail.com

# Option B — Gmail on port 587 (STARTTLS)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_USER=eliseeweb@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=eliseeweb@gmail.com