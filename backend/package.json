{
  "name": "dg-property-crm-backend",
  "version": "1.0.0",
  "description": "Backend API for DG Property CRM",
  "main": "dist/server.js",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\start-backend.ps1",
    "dev:server": "ts-node --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "tsc && node scripts/resolve-dist-paths.js",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "prisma:generate": "prisma generate",
    "postprisma:generate": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\sync-backend-prisma-hash.ps1",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "crm",
    "property",
    "real-estate"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^8.5.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "socket.io": "^4.8.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^7.0.11",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "prisma": "^5.7.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
